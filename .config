# ==================== 平台核心锁定 ====================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_generic=y
CONFIG_arm64=y
CONFIG_aarch64=y
CONFIG_CPU_TYPE="cortex-a53"

# ==================== 固件镜像（TF卡专用） ====================
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4=y
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_IMAGES_SDCARD=y

# ==================== 基础系统 & 中文 ====================
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ==================== USB/串口/5G模组必备驱动 ====================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y

# QMI/MBIM 拨号协议
CONFIG_PACKAGE_luci-proto-qmi=y
CONFIG_PACKAGE_luci-proto-mbim=y
CONFIG_PACKAGE_qmi-utils=y
CONFIG_PACKAGE_mbim-network=y

# ==================== 网卡 & 2.5G PHY驱动 ====================
CONFIG_PACKAGE_kmod-phy-aquantia=y
CONFIG_PACKAGE_kmod-phy-mt7530=y
CONFIG_PACKAGE_kmod-netlink-diag=y

# ==================== WiFi MT7987 固件驱动 ====================
CONFIG_PACKAGE_kmod-mt7987-firmware=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_wpad-full=y

# ==================== 常用刚需插件（预装） ====================
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-cifs-mount=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-cp936=y

# ==================== 网络基础组件 ====================
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# ==================== 修正 ====================
#CONFIG_PACKAGE_libopenssl=y
#CONFIG_OPENSSL_WITH_DTLS=y 
